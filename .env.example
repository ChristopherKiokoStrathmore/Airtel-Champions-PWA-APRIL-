# ========== SUPABASE CONFIGURATION ==========
# Get these from your Supabase project: Settings > API > Project URL and Anon Key
# URL: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here-40-chars-minimum
VITE_SUPABASE_PROJECT_ID=your-project-id-only

# Service Role Key (BACKEND ONLY - NEVER expose in frontend!)
# Use only in server-side functions, Edge Functions, or scripts
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========== DEPLOYMENT ==========
# Vercel environment indicator
VITE_VERCEL_ENV=development
# API base URL
VITE_API_URL=http://localhost:5173

# ========== FEATURES ==========
# Progressive Web App settings
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true

# ========== LOGGING ==========
# Log level: trace, debug, info, warn, error
VITE_LOG_LEVEL=info
VITE_DEBUG=false

# ========== OPTIONAL: THIRD-PARTY APIS ==========
# GitHub Token (for automated workflows)
# GITHUB_TOKEN=your-github-token-here
# 
# Groq API (for AI features)
# GROQ_API_KEY=your-groq-api-key-here
#
# Vercel Deployment Token (for CLI)
# VERCEL_TOKEN=your-vercel-token
